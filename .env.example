# ========================================
# VARIÁVEIS DE AMBIENTE - GESTFY
# ========================================

# DATABASE NEON (PostgreSQL)
# Copie a URL de conexão do seu banco NEON
# Formato: postgresql://user:password@host:port/database
DB_URL=postgresql://seu_usuario:sua_senha@ep-seu-projeto.neon.tech/neon

# Usuário do banco de dados
DB_USERNAME=seu_usuario_neon

# Senha do banco de dados  
DB_PASSWORD=sua_senha_neon

# ========================================
# IMPORTANTE PARA DEPLOYMENT NO RENDER
# ========================================
# 1. Vá para https://dashboard.render.com
# 2. Crie um novo Web Service (ou edite o existente)
# 3. Em "Build Command": ./mvnw clean package -DskipTests
# 4. Em "Start Command": java -jar target/gestfy-0.0.1-SNAPSHOT.jar
# 5. Adicione as variáveis de ambiente acima em "Environment"
# 6. Deploy!
